<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="EekContextMenu.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:EekContextMenu"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <Grid
        Padding="48,16,48,20"
        HorizontalAlignment="Stretch"
        RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="2">
            <TextBlock
                Style="{ThemeResource TitleTextBlockStyle}"
                Text="EEK Context Menu" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Explorer folder scans with Emsisoft Emergency Kit" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Padding="12"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="10">
                <TextBlock
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    Text="Emsisoft Emergency Kit folder" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="EekPathBox"
                        PlaceholderText="C:\EEK"
                        TextChanged="Setting_Changed" />
                    <Button
                        x:Name="BrowseButton"
                        Grid.Column="1"
                        Width="40"
                        Height="40"
                        Padding="0"
                        Click="BrowseButton_Click"
                        ToolTipService.ToolTip="Browse">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="18"
                            Glyph="&#xE8B7;"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <Border
            Grid.Row="2"
            Padding="12"
            HorizontalAlignment="Stretch"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid RowSpacing="8" ColumnSpacing="18" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        Text="Show Explorer command" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Adds Scan with EEK for folders" />
                </StackPanel>
                <ToggleSwitch
                    x:Name="IntegrationToggle"
                    Grid.Row="0"
                    Grid.Column="1"
                    Width="64"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    OffContent=""
                    OnContent=""
                    Toggled="Setting_Changed" />

                <StackPanel Grid.Row="1" Grid.Column="0">
                    <TextBlock
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        Text="Update before scan" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Runs EEK signature update first" />
                </StackPanel>
                <ToggleSwitch
                    x:Name="UpdateBeforeScanToggle"
                    Grid.Row="1"
                    Grid.Column="1"
                    Width="64"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    OffContent=""
                    OnContent=""
                    Toggled="Setting_Changed" />

                <StackPanel Grid.Row="2" Grid.Column="0">
                    <TextBlock
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        Text="Move detections to quarantine" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Uses the EEK quarantine folder" />
                </StackPanel>
                <ToggleSwitch
                    x:Name="QuarantineToggle"
                    Grid.Row="2"
                    Grid.Column="1"
                    Width="64"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    OffContent=""
                    OnContent=""
                    Toggled="Setting_Changed" />
            </Grid>
        </Border>
    </Grid>
</Page>
