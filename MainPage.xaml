<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="EekContextMenu.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:EekContextMenu"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid
            MaxWidth="720"
            Padding="32"
            HorizontalAlignment="Left">
            <StackPanel Spacing="24">
                <TextBlock
                    Style="{ThemeResource TitleTextBlockStyle}"
                    Text="EEK Context Menu" />

                <InfoBar
                    x:Name="StatusInfoBar"
                    IsClosable="False"
                    IsOpen="False" />

                <StackPanel Spacing="8">
                    <TextBlock
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        Text="Emsisoft Emergency Kit folder" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="EekPathBox"
                            MinWidth="420"
                            PlaceholderText="C:\EEK" />
                        <Button
                            x:Name="BrowseButton"
                            Grid.Column="1"
                            Width="40"
                            Height="40"
                            Click="BrowseButton_Click"
                            ToolTipService.ToolTip="Browse">
                            <FontIcon FontSize="16" Glyph="&#xE8B7;" />
                        </Button>
                    </Grid>
                </StackPanel>

                <ToggleSwitch
                    x:Name="IntegrationToggle"
                    Header="Explorer integration"
                    OffContent="Disabled"
                    OnContent="Enabled"
                    Toggled="IntegrationToggle_Toggled" />

                <Button
                    x:Name="SaveButton"
                    Click="SaveButton_Click"
                    Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="16" Glyph="&#xE74E;" />
                        <TextBlock Text="Save" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
